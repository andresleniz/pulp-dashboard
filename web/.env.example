DATABASE_URL=postgresql://postgres:password@localhost:5432/pulp_pricing
NEXT_PUBLIC_APP_NAME=Pulp Pricing Intelligence

# ── AI Layer ──────────────────────────────────────────────────────────────────
# Provider: only 'anthropic' supported currently
AI_PROVIDER=anthropic

# Model to use. Haiku is fast and cost-effective for extraction.
# Use claude-sonnet-4-6 for higher accuracy on complex expert report excerpts.
AI_MODEL=claude-haiku-4-5-20251001

# Anthropic API key — required for AI features
# Get yours at console.anthropic.com
# If not set, the app runs in rules-only mode. No crash, no silent fallback.
ANTHROPIC_API_KEY=
